    "남긴 메모와 답글도 함께 사라져요. 되돌릴 수 없어요." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your note and any replies go too. This can't be undone."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपका नोट और सभी जवाब भी हट जाएँगे. इसे वापस नहीं लाया जा सकता."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "残したメモや返信も一緒に消えます。元に戻せません。"
          }
        },
