    "글·시리즈·댓글이 모두 삭제 대상이 됩니다.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your posts, series and comments will all be deleted."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
