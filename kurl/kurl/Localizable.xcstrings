    "닫기" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Close"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "बंद करें"
          }
        },
