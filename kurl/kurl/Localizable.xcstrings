        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "पसंद, बुकमार्क, सब्सक्रिप्शन और लेखन तक — एक ही खाता, वेब जैसा."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "いいね・ブックマーク・購読、そして執筆まで — ウェブと同じひとつのアカウントでつながります。"
