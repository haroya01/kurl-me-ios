{
  "sourceLanguage": "ko",
  "strings": {
    "kurl 분석": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "kurl Analytics"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "kurl 分析"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phân tích kurl"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "kurl विश्लेषण"
          }
        }
      }
    },
    "누적 조회": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Total views"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "累計閲覧"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tổng lượt xem"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कुल व्यूज़"
          }
        }
      }
    },
    "발행한 글": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Published"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "公開記事"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đã đăng"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रकाशित"
          }
        }
      }
    },
    "블로그 분석": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Blog Analytics"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブログ分析"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phân tích blog"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ब्लॉग विश्लेषण"
          }
        }
      }
    },
    "앱에서 분석을 한 번 열면\n여기에 지표가 떠요.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Analytics in the app once\nand your stats will appear here."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリで分析を一度開くと\nここに指標が表示されます。"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mở Phân tích trong ứng dụng một lần\nrồi số liệu của bạn sẽ hiện ở đây."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऐप में विश्लेषण एक बार खोलें\nऔर आपके आँकड़े यहाँ दिखेंगे."
          }
        }
      }
    },
    "조회": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "views"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "閲覧"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "lượt xem"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "व्यूज़"
          }
        }
      }
    },
    "좋아요": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Likes"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "いいね"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lượt thích"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पसंद"
          }
        }
      }
    },
    "최근 %lld일 조회": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Views, last %lld days"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "直近%lld日の閲覧"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lượt xem, %lld ngày qua"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "व्यूज़, पिछले %lld दिन"
          }
        }
      }
    },
    "최근 조회수와 누적 지표를 홈 화면에서.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recent views and lifetime stats on your Home Screen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最近の閲覧数と累計指標をホーム画面で。"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lượt xem gần đây và số liệu tích lũy ngay trên Màn hình chính."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हाल के व्यूज़ और कुल आँकड़े आपकी होम स्क्रीन पर."
          }
        }
      }
    },
    "팔로워": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Followers"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フォロワー"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Người theo dõi"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ॉलोअर"
          }
        }
      }
    }
  },
  "version": "1.0"
}
