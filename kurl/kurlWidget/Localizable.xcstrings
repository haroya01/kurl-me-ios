{
  "sourceLanguage": "ko",
  "strings": {
    "%lld편 보관": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld saved"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld件保存"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld đã lưu"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld सहेजे गए"
          }
        }
      }
    },
    "글을 북마크하면": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bookmark a post"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "記事をブックマークすると"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đánh dấu một bài viết"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "किसी पोस्ट को बुकमार्क करें"
          }
        }
      }
    },
    "북마크한 글이 홈 화면에 한 장씩.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your bookmarked posts, one at a time on your Home Screen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブックマークした記事をホーム画面に一冊ずつ。"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bài viết đã đánh dấu, hiện từng cái trên Màn hình chính."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपकी बुकमार्क की गई पोस्ट, होम स्क्रीन पर एक-एक कर."
          }
        }
      }
    },
    "서재": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Library"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "本棚"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thư viện"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "लाइब्रेरी"
          }
        }
      }
    },
    "여기 한 장씩 꽂혀요.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "and it appears here, one at a time."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ここに一冊ずつ並びます。"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "và nó xuất hiện ở đây, từng cái một."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "और वह यहाँ एक-एक कर दिखेगी."
          }
        }
      }
    },
    "kurl 분석": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "kurl Analytics"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "kurl 分析"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phân tích kurl"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "kurl विश्लेषण"
          }
        }
      }
    },
    "누적 조회": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Total views"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "累計閲覧"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tổng lượt xem"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कुल व्यूज़"
          }
        }
      }
    },
    "발행한 글": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Published"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "公開記事"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Đã đăng"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "प्रकाशित"
          }
        }
      }
    },
    "블로그 분석": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Blog Analytics"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブログ分析"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phân tích blog"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ब्लॉग विश्लेषण"
          }
        }
      }
    },
    "앱을 열면 여기에\n최근 지표가 떠요.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open the app and your\nlatest stats will appear here."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリを開くと\n最新の指標がここに表示されます。"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mở ứng dụng và số liệu\nmới nhất sẽ hiện ở đây."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऐप खोलें, आपके ताज़ा\nआँकड़े यहाँ दिखेंगे."
          }
        }
      }
    },
    "조회": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "views"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "閲覧"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "lượt xem"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "व्यूज़"
          }
        }
      }
    },
    "좋아요": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Likes"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "いいね"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lượt thích"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पसंद"
          }
        }
      }
    },
    "최근 %lld일 조회": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Views, last %lld days"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "直近%lld日の閲覧"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lượt xem, %lld ngày qua"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "व्यूज़, पिछले %lld दिन"
          }
        }
      }
    },
    "최근 조회수와 누적 지표를 홈 화면에서.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Recent views and lifetime stats on your Home Screen."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最近の閲覧数と累計指標をホーム画面で。"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lượt xem gần đây và số liệu tích lũy ngay trên Màn hình chính."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हाल के व्यूज़ और कुल आँकड़े आपकी होम स्क्रीन पर."
          }
        }
      }
    },
    "팔로워": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Followers"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フォロワー"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Người theo dõi"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "फ़ॉलोअर"
          }
        }
      }
    }
  },
  "version": "1.0"
}
